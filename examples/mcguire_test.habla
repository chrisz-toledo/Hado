# mcguire_test.habla
# Demo script que valida las nuevas features del compilador:
#   - Comentarios con # (hash)
#   - Pipe operator | como alternativa a ->
#   - Argumentos multiples en genera reporte con a, b, c
#   - Alias 'report' (ingles) en genera report
#   - Sintaxis escanea ports de target

// ─── Configuracion del target ────────────────────────────────────────────────

target = "scanme.nmap.org"
dominio = "nmap.org"

# Lista de ports comunes a verificar
ports_web = [80, 443, 8080, 8443]
ports_ssh = [22, 2222]

// ─── FEATURE 1: Comentarios con # y pipe | ───────────────────────────────────

# Pipe chain usando | como operador (equivalente a ->)
muestra "=== Test: pipe operator | ==="
busca subdomains de dominio | filtra alive | muestra

// ─── FEATURE 2: escanea ports de target ─────────────────────────────────────

muestra "=== Test: escanea ports de target ==="
# Escaneo rapido con ports por defecto (21,22,23,25,80,443,3306,5432,8080,8443)
escanea ports de target

// ─── FEATURE 3: Escaneo con pipe chain usando | ─────────────────────────────

muestra "=== Test: scan + pipe chain ==="
escanea target en ports [80, 443] | genera reporte

// ─── FEATURE 4: genera report con multiples argumentos ──────────────────────

muestra "=== Test: genera report con argumentos multiples ==="

scan_result = escanea target en ports ports_web

# Datos adicionales del entorno
info = "Target: " + target
contexto = "Ports analizados: " + cuenta ports_web

# genera report acepta lista de argumentos separados por coma
genera report con scan_result, info, contexto

// ─── FEATURE 5: Alias 'report' (ingles) ─────────────────────────────────────

muestra "=== Test: alias report (ingles) ==="
subs = busca subdomains de dominio

# Ambos 'reporte' y 'report' son validos
genera report con subs

// ─── FEATURE 6: Pipe completo con | en lugar de -> ──────────────────────────

muestra "=== Test: full pipeline con | ==="

# Pipeline completo de recon usando | como separador
busca subdomains de dominio | filtra alive | genera reporte

// ─── Fin del test ────────────────────────────────────────────────────────────

muestra "=== mcguire_test completado ==="
muestra "Features validadas: #comments, | pipe, multi-args, report alias, ports de"
